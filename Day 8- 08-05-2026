// Polymorphism means one name but many forms
//same function behaves diffrently depending on the type of the object it called
// two Types
//compile time Polymorphism -- function Overloading -- static
// Resolved at compile time 
// function overloads -- same function name, but diffrent prameters 
// faster execution
// run time Polymorphism -- function overriding -- Dynamic 
// Resolved at run time
//function runtime -- some function name, same prameters, but diffrent class
// uses a virtual keyword in the base class
// achieving this through the concept of inheritance

// Types of Polymorphism -- 2.1
// function Overloadin

#include <iostream>
using namespace std; 

int multiply(int a, int b){
    return a*b;
}


double multiply(double a, double b, double c) {
    return a*b*c;
}


int main() {
    cout << multiply(3,4)<<"\n";
    cout << multiply(3.0,4.5,6.0);
    return 0;
}









