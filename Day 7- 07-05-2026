// problem 3
// Pillar of OOPS
// Encapsulation
// Encapsulation means we are binding the data into a single unit(Functions, data, varaiables, methods)
// into a single unit called and making some restrictions on this class members
// data security
// controlled access over my data
// validation before accessing the data
// code maintainaility

#include <iostream>
using namespace std;

class bankAccount{
private:    
int balance;

public:
void setBalance(int amount) {
    if(amount >= 0) {
        balance = amount;
    } else {
        cout << "Enter a valid Number...";
    }
}
int getbalance() {
    return balance;
    }
};
int main() {
    bankAccount obj1;
    obj1.setBalance(5000);
    cout << obj1.getbalance();
}

    
    
    






