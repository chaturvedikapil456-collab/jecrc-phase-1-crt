// problem 5
//smat ac remote
//function overloading
//default argument

#include <iostream>
using namespace std;

void setTemperature(int temp = 22){
    cout<<"temp set to"<<temp<<"C"<<"\n";
}
void setTemperature(double temp){
    cout<<"temp set to"<<temp<<"C"<<"\n";
}
void setTemperature(string mode){
    if(mode =="Eco"){
        cout<<"temp set to 24 C"<<"\n";
    }else if(mode == "TURBO"){
        cout<<"temp set to 18C"<<"\n";
    }
}

    

int main(){
    setTemperature(); //default value-- 22
    setTemperature(20.5);//manually setting the temp 
    setTemperature("Eco");//set temp to 24
    setTemperature("TURBO");
    
    return 0;
}

