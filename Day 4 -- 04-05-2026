    // problem 4 
// Print mirror of right angled triangle

#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    // number of times or number of rows
    for(int i = 1; i <= n; i++) {
        // number of spaces logic is here 
        for(int j = n-i; j >= 1; j--) {
            cout << " ";
        }
        for(int k = 1; k <= i; k++) {
            cout << "*";
        }
        cout << "\n";
    }
       return 0; 
    }
     

    
    
    

