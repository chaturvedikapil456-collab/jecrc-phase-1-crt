// problem 4 -- Ternary operator
// find the greater number among 2
#include <iostream>
using namespace std;

int main() {
    int a, b;
    int max_Number;
    
    cin >> a >> b;
    // Ternary operator
    max_Number = (a > b) ? a : b;
    cout << max_Number;
    return 0;
}





// problem 5 -- Continue Statement 
// Print 1 to N and avoid those number which are divisible by 3 
#include <iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    for(int i = 1; i <= n; i++) {
        if( i % 3 == 0){
            continue;
        }
    cout << i <<  " ";
    }
    cout << "\n";
    return 0;
}


// problem 6 -- Break statement
// we have to add numbers until we get a negative numbers

#include <iostream>
using namespace std;

int main(){
    int n;
    int sum = 0;
    
    while(true) {
        cin >> n;
   
      if(n < 0){   
        break;
    }
    sum = sum + n;
  }
 
 cout << sum;
 return 0;
 }



