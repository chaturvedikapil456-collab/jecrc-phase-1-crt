// temprature conversion
// Take input in the form of Celcius and convert it into fahreneit...

#include<iostream>
using namespace std;

int main(){
    
    double celcuis;
    double fahreneit;
    cin >> celcuis;
    fahreneit = (celcuis * 9.0 / 5.0) + 32.0;
    cout << fahreneit << endl;
     
     return 0;
     
}



// GLOBAL VS LOCAL VARIABLE

#include<iostream>
using namespace std;


// global variable
int globalVariable = 100;
int main(){
    // local variable 
    int userInput;
    float result;
    
    cin >> userInput;
    result = (double)globalVariable / userInput;
    
    cout << result <<endl;
    return 0;
    
}
